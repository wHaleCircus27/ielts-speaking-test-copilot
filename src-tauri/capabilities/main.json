{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Local main window access to the minimum IPC commands required by the application.",
  "windows": ["main"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "allow-health-check",
    "allow-get-app-config",
    "allow-save-app-config",
    "allow-clear-deepseek-key",
    "allow-clear-zhipu-key",
    "allow-clear-azure-key",
    "allow-accept-cloud-disclosure",
    "allow-validate-azure-config",
    "allow-issue-azure-speech-token",
    "allow-validate-deepseek-config",
    "allow-grade-speaking",
    "allow-create-teacher-case",
    "allow-list-teacher-cases",
    "allow-get-teacher-case",
    "allow-update-teacher-case",
    "allow-delete-teacher-case",
    "allow-rebuild-teacher-case-embedding",
    "allow-search-teacher-cases",
    "allow-diagnose-teacher-case-search",
    "allow-select-media-file",
    "allow-get-media-metadata",
    "allow-transcode-media",
    "allow-cancel-media-transcode",
    "allow-delete-generated-media-file",
    "allow-reconcile-generated-media"
  ]
}
