{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "雅思口语智能批改助手",
  "version": "../package.json",
  "identifier": "com.local.ielts-speaking-test-copilot",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "雅思口语智能批改助手",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "capabilities": ["main"],
      "freezePrototype": true,
      "csp": {
        "default-src": "'self' customprotocol:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost asset: http://asset.localhost https://asset.localhost wss://*.stt.speech.microsoft.com",
        "font-src": "'self'",
        "img-src": "'self' data:",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-src": "'none'",
        "frame-ancestors": "'none'",
        "form-action": "'none'",
        "script-src": "'self'",
        "style-src": "'self'"
      },
      "devCsp": {
        "default-src": "'self' http://localhost:1420 customprotocol:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost asset: http://asset.localhost https://asset.localhost http://localhost:1420 ws://localhost:1420 wss://*.stt.speech.microsoft.com",
        "font-src": "'self' http://localhost:1420",
        "img-src": "'self' data: blob: http://localhost:1420",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-src": "'none'",
        "frame-ancestors": "'none'",
        "form-action": "'none'",
        "script-src": "'self' 'unsafe-eval' http://localhost:1420",
        "style-src": "'self' 'unsafe-inline' http://localhost:1420"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/generated-media/*.wav"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": {
      "../LICENSE": "LICENSE",
      "../NOTICE": "NOTICE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    },
    "copyright": "Copyright 2026 wHaleCircus27",
    "license": "Apache-2.0",
    "category": "Education",
    "macOS": {
      "bundleVersion": "1",
      "minimumSystemVersion": "15.0",
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
